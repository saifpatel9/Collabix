{
  "name": "collabix-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:css dev:js",
    "dev:css": "tailwindcss -i ./backend/frontend/src/css/app.css -o ./backend/static/dist/css/app.css --watch",
    "dev:js": "esbuild ./backend/frontend/src/js/app.js --bundle --outfile=./backend/static/dist/js/app.js --watch",
    "build:css": "tailwindcss -i ./backend/frontend/src/css/app.css -o ./backend/static/dist/css/app.css --minify",
    "build:js": "esbuild ./backend/frontend/src/js/app.js --bundle --minify --outfile=./backend/static/dist/js/app.js",
    "build": "npm run build:css && npm run build:js",
    "format": "prettier --write \"backend/templates/**/*.html\" \"backend/frontend/src/**/*.{js,css}\""
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "alpinejs": "^3.14.9",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.0",
    "htmx.org": "^2.0.4",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^3.4.17"
  }
}
