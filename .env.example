DJANGO_SETTINGS_MODULE=config.settings.development
# Use a secure random value in production
DJANGO_SECRET_KEY=replace-with-secure-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

DJANGO_TIME_ZONE=Asia/Kolkata
DJANGO_LOG_LEVEL=INFO

# Add any origins you need for CSRF when running behind a host/port
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Security toggles for production (set to True only in production with HTTPS)
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=31536000

# Development convenience: set to True to force use of SQLite database
# instead of MySQL for local development without installing MySQL.
DJANGO_FORCE_SQLITE=True

# MySQL (optional)
MYSQL_DATABASE=collabix
MYSQL_USER=collabix
MYSQL_PASSWORD=changeme
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=changeme

# Redis (optional)
REDIS_URL=redis://127.0.0.1:6379/1

# CORS
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# JWT
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7